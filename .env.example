DATABASE_URL=postgresql+asyncpg://app:app@postgres:5432/app
REDIS_URL=redis://redis:6379/0
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672//

SESSION_SECRET=change-me-32-bytes-minimum-please
SERVER_PEPPER=change-me-32-bytes-minimum-please
FERNET_KEY=

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
S3_INPUT_BUCKET=demo-bda-inputs
S3_OUTPUT_BUCKET=demo-bda-outputs

BDA_PROJECT_ARN=arn:aws:bedrock:us-east-1:123:data-automation-project/abc
BDA_PROFILE_ARN=arn:aws:bedrock:us-east-1:123:data-automation-profile/us.data-automation-v1

RUN_MIGRATIONS_ON_STARTUP=true
LOG_LEVEL=INFO
CELERY_CONCURRENCY=10
RATE_LIMIT_UPLOAD=60/minute
RATE_LIMIT_READ=300/minute
MAX_FILE_SIZE_MB=10
MAX_BATCH_SIZE=10
COOKIE_SECURE=false
